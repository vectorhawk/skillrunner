{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["text", "target_audience"],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "description": "The text to analyze and rewrite."
    },
    "target_audience": {
      "type": "string",
      "minLength": 1,
      "description": "Short description of who the rewrite is for."
    }
  },
  "additionalProperties": false
}
