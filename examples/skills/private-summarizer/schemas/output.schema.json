{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["summary", "word_count"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "A 2-4 sentence summary of the input text."
    },
    "word_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of words in the original input."
    }
  },
  "additionalProperties": false
}
